generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  username   String       @unique
  password   String
  submission Submission[]
}

model Submission {
  id       String  @id @default(uuid())
  user     User    @relation(fields: [userId], references: [id])
  userId   String
  code     String?
  language String
}
